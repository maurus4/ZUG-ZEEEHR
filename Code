<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SBB | Live Monitor & Verbindungen</title>
    <!-- Leaflet CSS für die Karte -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        :root {
            --sbb-red: #EB0000;
            --sbb-anthracite: #2D2D2D;
            --sbb-white: #FFFFFF;
            --sbb-light-grey: #F6F6F6;
            --sbb-grey: #666666;
            --nordic-bg: #F9FAFB;
            --border-radius: 4px;
        }
 
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "SBB Web", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
 
        body {
            background-color: var(--nordic-bg);
            color: var(--sbb-anthracite);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            overflow-x: hidden;
        }
 
        header {
            background-color: var(--sbb-white);
            padding: 1.5rem 5%;
            border-bottom: 1px solid #E5E5E5;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }
 
        .logo {
            font-weight: 900;
            font-size: 1.2rem;
            letter-spacing: -0.5px;
            color: var(--sbb-red);
            text-transform: uppercase;
        }
 
        main {
            flex: 1;
            padding: 3rem 5%;
            max-width: 1000px;
            margin: 0 auto;
            width: 100%;
        }
 
        /* Hero Section für Verspätung */
        .hero-section {
            background: var(--sbb-white);
            padding: 3rem 2rem;
            border-radius: var(--border-radius);
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            text-align: center;
            margin-bottom: 3rem;
            border-top: 4px solid var(--sbb-red);
        }
 
        .label {
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 2px;
            color: var(--sbb-grey);
            margin-bottom: 1rem;
            display: block;
            font-weight: 600;
        }
 
        .delay-value {
            font-size: clamp(2.5rem, 8vw, 5rem);
            font-weight: 900;
            line-height: 1;
            color: var(--sbb-red);
            margin-bottom: 0.5rem;
        }
 
        .station-name {
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--sbb-anthracite);
            margin-bottom: 0.5rem;
        }
 
        .delay-details {
            display: inline-flex;
            gap: 1rem;
            background: var(--sbb-light-grey);
            padding: 0.8rem 1.5rem;
            border-radius: 50px;
            font-size: 0.9rem;
            color: var(--sbb-anthracite);
            margin-top: 1rem;
            flex-wrap: wrap;
            justify-content: center;
        }
 
        .badge-train {
            background: var(--sbb-anthracite);
            color: white;
            padding: 0.2rem 0.6rem;
            border-radius: 3px;
            font-weight: bold;
            font-size: 0.8rem;
        }
 
        /* Team Banner / Hero Image */
        .team-banner {
            width: 100%;
            margin-bottom: 3rem;
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            background-color: var(--sbb-white);
            border-top: 4px solid var(--sbb-red);
        }
 
        .team-banner img {
            width: 100%;
            height: auto;
            max-height: 450px;
            object-fit: cover;
            display: block;
        }
 
        /* Connection Search Section */
        .search-container {
            background: var(--sbb-white);
            padding: 2.5rem;
            border-radius: var(--border-radius);
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            margin-bottom: 3rem;
        }
 
        .search-grid {
            display: grid;
            grid-template-columns: 1fr 1fr auto;
            gap: 1.5rem;
            align-items: end;
        }
 
        .input-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
 
        .input-group label {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--sbb-grey);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
 
        input {
            padding: 1rem 1.2rem;
            border: 1px solid #E5E5E5;
            border-radius: var(--border-radius);
            font-size: 1.1rem;
            outline: none;
            transition: all 0.2s;
            background: var(--nordic-bg);
        }
 
        input:focus {
            border-color: var(--sbb-red);
            background: var(--sbb-white);
            box-shadow: 0 0 0 3px rgba(235, 0, 0, 0.1);
        }
 
        /* Results List */
        #connection-results {
            margin-top: 2.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
 
        .connection-card {
            border: 1px solid #E5E5E5;
            border-radius: var(--border-radius);
            padding: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--sbb-white);
            transition: transform 0.2s, box-shadow 0.2s;
        }
 
        .connection-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.06);
            border-color: #D1D1D1;
        }
 
        .journey-main {
            display: flex;
            align-items: center;
            gap: 2rem;
            flex: 1;
        }
 
        .time-block {
            display: flex;
            flex-direction: column;
        }
 
        .time {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--sbb-anthracite);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
 
        .delay-text {
            color: var(--sbb-red);
            font-size: 0.9rem;
            font-weight: 600;
        }
 
        .station {
            color: var(--sbb-grey);
            font-size: 0.9rem;
            margin-top: 0.2rem;
        }
 
        .platform {
            font-size: 0.85rem;
            color: var(--sbb-anthracite);
            font-weight: 600;
            background: var(--sbb-light-grey);
            padding: 0.1rem 0.4rem;
            border-radius: 2px;
            margin-top: 0.3rem;
            display: inline-block;
            width: fit-content;
        }
 
        .journey-arrow {
            color: #CCC;
            font-size: 1.5rem;
        }
 
        .journey-meta {
            text-align: right;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            min-width: 120px;
        }
 
        .meta-text {
            font-size: 0.9rem;
            color: var(--sbb-grey);
        }
 
        .products {
            display: flex;
            gap: 0.3rem;
            justify-content: flex-end;
            flex-wrap: wrap;
        }
 
        /* Map Styling */
        #map-container {
            height: 350px;
            width: 100%;
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            background: #eee;
            border: 1px solid #E5E5E5;
        }
 
        #map { height: 100%; width: 100%; }
 
        /* Buttons */
        .btn {
            background-color: var(--sbb-anthracite);
            color: white;
            border: none;
            padding: 1rem 2rem;
            border-radius: var(--border-radius);
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
 
        .btn:hover { background-color: #000; }
 
        .btn-red { background-color: var(--sbb-red); }
        .btn-red:hover { background-color: #c00000; }
 
        @media (max-width: 768px) {
            .search-grid { grid-template-columns: 1fr; }
            .connection-card { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
            .journey-main { width: 100%; justify-content: space-between; }
            .journey-meta { text-align: left; width: 100%; flex-direction: row; justify-content: space-between; align-items: center; border-top: 1px solid #eee; padding-top: 1rem;}
        }
    </style>
</head>
<body>
 
    <header>
        <div class="logo">SBB CFF FFS</div>
        <button onclick="fetchDelays()" class="btn" style="padding: 0.6rem 1.2rem; font-size: 0.8rem;">Live Radar Update</button>
    </header>
 
    <main>
        <!-- Team Banner Image -->
        <div class="team-banner">
            <img src="ChatGPT Image 19. März 2026, 16_48_03.jpg" alt="ANGINF - Wir führen die Informatik in die Zukunft" onerror="this.style.display='none'">
        </div>
 
        <!-- Top Delay Monitor -->
        <section class="hero-section">
            <span class="label">Aktueller Störungsschwerpunkt</span>
            <div id="delay-display" class="delay-value">Lädt...</div>
            <div id="station-display" class="station-name">System scannt Netzwerk</div>
            <div id="detail-display" class="delay-details" style="display: none;">
                <!-- Dynamisch gefüllt -->
            </div>
        </section>
 
        <!-- Connection Search -->
        <section class="search-container">
            <h2 style="margin-bottom: 2rem; font-size: 1.4rem; font-weight: 600; color: var(--sbb-anthracite);">Fahrplan & Tickets</h2>
            <div class="search-grid">
                <div class="input-group">
                    <label>Von</label>
                    <input type="text" id="from-station" placeholder="z.B. Zürich HB" value="Bern">
                </div>
                <div class="input-group">
                    <label>Nach</label>
                    <input type="text" id="to-station" placeholder="z.B. Bern" value="Zürich HB">
                </div>
                <button onclick="findConnections()" class="btn btn-red">Verbindung suchen</button>
            </div>
 
            <div id="connection-results">
                <!-- Dynamische Ergebnisse hier -->
            </div>
        </section>
 
        <!-- Map Section -->
        <span class="label" style="margin-bottom: 1rem;">Live Netzwerk-Radar</span>
        <div id="map-container">
            <div id="map"></div>
        </div>
    </main>
 
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const HUBS = ["Zürich HB", "Bern", "Basel SBB", "Lausanne", "Genève", "Luzern", "St. Gallen", "Lugano", "Olten", "Winterthur"];
        let map;
        let markers = [];
 
        function initMap() {
            map = L.map('map', { zoomControl: false, attributionControl: false }).setView([46.8182, 8.2275], 8);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(map);
        }
 
        // --- HILFSFUNKTIONEN ---
        function formatTime(isoString) {
            if (!isoString) return '';
            const date = new Date(isoString);
            return date.toLocaleTimeString('de-CH', { hour: '2-digit', minute: '2-digit' });
        }
 
        function formatDuration(durationStr) {
            // SBB API Duration format: "00d00:56:00"
            if (!durationStr) return '';
            const match = durationStr.match(/(\d+)d(\d+):(\d+):(\d+)/);
            if (match) {
                const hours = parseInt(match[2], 10);
                const minutes = parseInt(match[3], 10);
                if (hours > 0) return `${hours} h ${minutes} min`;
                return `${minutes} min`;
            }
            return durationStr;
        }
 
        // --- VERSPÄTUNGS-MONITOR LOGIK ---
        async function fetchDelays() {
            const delayDisplay = document.getElementById('delay-display');
            const stationDisplay = document.getElementById('station-display');
            const detailDisplay = document.getElementById('detail-display');
            
            try {
                const requests = HUBS.map(hub =>
                    fetch(`https://transport.opendata.ch/v1/stationboard?station=${encodeURIComponent(hub)}&limit=15`)
                    .then(res => res.json()).catch(() => null)
                );
 
                const results = await Promise.all(requests);
                
                // Alte Marker von der Karte entfernen
                markers.forEach(m => map.removeLayer(m));
                markers = [];
 
                let globalMaxDelay = -1;
                let globalWorstTrain = null;
 
                results.forEach(data => {
                    if (!data || !data.stationboard) return;
                    
                    let hubMaxDelay = 0;
                    let hubWorstTrain = null;
 
                    data.stationboard.forEach(train => {
                        const delay = parseInt(train.prognosis?.delay) || 0;
                        if (delay > hubMaxDelay && delay < 300) {
                            hubMaxDelay = delay;
                            hubWorstTrain = {
                                station: data.station.name,
                                destination: train.to,
                                category: train.category,
                                number: train.number,
                                scheduled: train.stop?.departure,
                                expected: train.prognosis?.departure,
                                coords: [data.station.coordinate.x, data.station.coordinate.y]
                            };
                        }
                    });
 
                    // Koordinaten des Bahnhofs (auch wenn keine Verspätung)
                    const coords = [data.station.coordinate.x, data.station.coordinate.y];
                    
                    // Marker auf der Karte platzieren (Grün für OK, Rot für Verspätung)
                    const isDelayed = hubMaxDelay > 0;
                    const markerColor = isDelayed ? "#EB0000" : "#00a650"; // SBB Rot oder SBB Pünktlichkeits-Grün
                    const markerRadius = isDelayed ? 12 : 6;
 
                    const m = L.circleMarker(coords, {
                        radius: markerRadius,
                        fillColor: markerColor,
                        color: "#fff",
                        weight: 2,
                        fillOpacity: 0.9
                    }).addTo(map);
 
                    if (isDelayed) {
                        m.bindPopup(`<b>${data.station.name}</b><br>Grösste Verspätung: +${hubMaxDelay} Min.<br>${hubWorstTrain.category} ${hubWorstTrain.number}`);
                        
                        // Checken ob es die absolut grösste Verspätung schweizweit ist
                        if (hubMaxDelay > globalMaxDelay) {
                            globalMaxDelay = hubMaxDelay;
                            globalWorstTrain = hubWorstTrain;
                        }
                    } else {
                        m.bindPopup(`<b>${data.station.name}</b><br>Keine nennenswerten Verspätungen.`);
                    }
                    
                    markers.push(m);
                });
 
                // Top Banner updaten
                if (globalWorstTrain && globalMaxDelay > 0) {
                    delayDisplay.innerText = `+${globalMaxDelay} min`;
                    delayDisplay.style.color = "var(--sbb-red)";
                    stationDisplay.innerText = globalWorstTrain.station;
                    
                    detailDisplay.style.display = 'inline-flex';
                    detailDisplay.innerHTML = `
                        <span class="badge-train">${globalWorstTrain.category} ${globalWorstTrain.number}</span>
                        <span>Richtung <strong>${globalWorstTrain.destination}</strong></span>
                        <span style="border-left: 1px solid #ccc; padding-left: 1rem;">
                            Geplant: ${formatTime(globalWorstTrain.scheduled)} | Erwartet: <strong>${formatTime(globalWorstTrain.expected)}</strong>
                        </span>
                    `;
                    
                    // Karte auf das grösste Problem zentrieren
                    map.flyTo(globalWorstTrain.coords, 10, { duration: 1.5 });
                } else {
                    delayDisplay.innerText = `Pünktlich`;
                    delayDisplay.style.color = "#00a650"; // Grün wenn alles ok
                    stationDisplay.innerText = "Alle überwachten Knotenpunkte laufen nach Plan.";
                    detailDisplay.style.display = 'none';
                    
                    // Karte auf die ganze Schweiz zentrieren, wenn alles OK ist
                    map.flyTo([46.8182, 8.2275], 8, { duration: 1.5 });
                }
            } catch (e) { console.error(e); }
        }
 
        // --- VERBINDUNGSSUCHE LOGIK ---
        async function findConnections() {
            const from = document.getElementById('from-station').value;
            const to = document.getElementById('to-station').value;
            const resultsDiv = document.getElementById('connection-results');
 
            if (!from || !to) return;
 
            resultsDiv.innerHTML = '<p style="padding: 2rem; text-align: center; color: var(--sbb-grey);">Suche Fahrplandaten...</p>';
 
            try {
                const response = await fetch(`https://transport.opendata.ch/v1/connections?from=${encodeURIComponent(from)}&to=${encodeURIComponent(to)}&limit=5`);
                const data = await response.json();
                
                resultsDiv.innerHTML = '';
 
                if (!data.connections || data.connections.length === 0) {
                    resultsDiv.innerHTML = '<p style="padding: 2rem; text-align: center;">Keine Verbindungen gefunden.</p>';
                    return;
                }
 
                data.connections.forEach(conn => {
                    // Zeiten
                    const depTime = formatTime(conn.from.departure);
                    const arrTime = formatTime(conn.to.arrival);
                    
                    // Verspätungen prüfen
                    const depDelayStr = conn.from.delay ? `<span class="delay-text">+${conn.from.delay}'</span>` : '';
                    const arrDelayStr = conn.to.delay ? `<span class="delay-text">+${conn.to.delay}'</span>` : '';
 
                    // Gleise / Plattform
                    const depPlatform = conn.from.platform ? `<div class="platform">Gl. ${conn.from.platform}</div>` : '';
                    const arrPlatform = conn.to.platform ? `<div class="platform">Gl. ${conn.to.platform}</div>` : '';
 
                    // Metadaten
                    const duration = formatDuration(conn.duration);
                    const transfers = conn.transfers === 0 ? 'Direkt' : `${conn.transfers}x Umsteigen`;
                    
                    // Verwendete Züge (Products)
                    const productsHtml = conn.products ? conn.products.map(p => `<span class="badge-train">${p}</span>`).join('') : '';
 
                    const item = document.createElement('div');
                    item.className = 'connection-card';
                    item.innerHTML = `
                        <div class="journey-main">
                            <div class="time-block">
                                <div class="time">${depTime} ${depDelayStr}</div>
                                <div class="station">${conn.from.station.name}</div>
                                ${depPlatform}
                            </div>
                            
                            <div class="journey-arrow">➔</div>
                            
                            <div class="time-block">
                                <div class="time">${arrTime} ${arrDelayStr}</div>
                                <div class="station">${conn.to.station.name}</div>
                                ${arrPlatform}
                            </div>
                        </div>
                        
                        <div class="journey-meta">
                            <div class="meta-text"><strong>${duration}</strong></div>
                            <div class="meta-text">${transfers}</div>
                            <div class="products" style="margin-top: 0.5rem;">${productsHtml}</div>
                        </div>
                    `;
                    resultsDiv.appendChild(item);
                });
 
            } catch (error) {
                resultsDiv.innerHTML = '<p style="padding: 2rem; color: var(--sbb-red); text-align: center;">Fehler bei der Verbindungssuche.</p>';
            }
        }
 
        window.onload = () => {
            initMap();
            fetchDelays();
            findConnections(); // Führt initial eine Suche Bern -> Zürich aus, damit die Seite nicht leer ist
        };
    </script>
</body>
</html>