<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SBB | Live Verspätungs-Radar</title>
    <!-- Leaflet CSS für die Karte -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        :root {
            --sbb-red: #EB0000;
            --sbb-anthracite: #2D2D2D;
            --sbb-white: #FFFFFF;
            --sbb-light-grey: #F6F6F6;
            --sbb-grey: #666666;
            --nordic-bg: #F0F2F5;
            --border-radius: 2px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "SBB Web", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--nordic-bg);
            color: var(--sbb-anthracite);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        header {
            background-color: var(--sbb-white);
            padding: 1rem 2rem;
            border-bottom: 1px solid #E5E5E5;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            flex-shrink: 0;
        }

        .logo {
            font-weight: 900;
            font-size: 1.2rem;
            letter-spacing: -0.5px;
            color: var(--sbb-red);
            text-transform: uppercase;
        }

        /* Dashboard Layout */
        main {
            flex: 1;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        /* Stats Overlay */
        .stats-panel {
            position: absolute;
            top: 20px;
            left: 20px;
            z-index: 1000;
            background: rgba(255, 255, 255, 0.95);
            padding: 1.5rem;
            border-radius: var(--border-radius);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            border-left: 4px solid var(--sbb-red);
            width: 320px;
            backdrop-filter: blur(5px);
        }

        .label {
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 1.5px;
            color: var(--sbb-grey);
            margin-bottom: 0.5rem;
            display: block;
            font-weight: 700;
        }

        .count-value {
            font-size: 2.5rem;
            font-weight: 900;
            color: var(--sbb-red);
            line-height: 1;
            cursor: pointer; /* NEU: Zeigt an, dass es klickbar ist */
            display: inline-block;
            transition: transform 0.2s ease;
        }

        .count-value:hover {
            transform: scale(1.05);
        }

        .sub-label {
            font-size: 0.85rem;
            color: var(--sbb-grey);
            margin-bottom: 1rem;
        }

        #map {
            width: 100%;
            height: 100%;
            background: #e0e0e0;
        }

        /* Custom Popup Styling */
        .leaflet-popup-content-wrapper {
            border-radius: var(--border-radius);
            padding: 5px;
        }

        .train-popup-title {
            font-weight: bold;
            color: var(--sbb-red);
            border-bottom: 1px solid #eee;
            margin-bottom: 5px;
            padding-bottom: 2px;
        }

        /* --- NEUE CSS KLASSEN FÜR BAHNHOFS-LABELS & POPUPS --- */
        .hub-label {
            background: transparent;
            border: none;
            padding: 0;
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--sbb-grey); /* Hier von --sbb-anthracite auf --sbb-grey gewechselt */
            text-align: center;
            white-space: nowrap;
            /* Weisser Halo-Effekt für Lesbarkeit direkt auf der Karte */
            text-shadow: 
                -1.5px -1.5px 0 #fff,  
                 1.5px -1.5px 0 #fff,
                -1.5px  1.5px 0 #fff,
                 1.5px  1.5px 0 #fff,
                 0px 0px 5px rgba(255,255,255,0.8);
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .hub-label:hover {
            color: var(--sbb-red);
            transform: scale(1.1);
            text-shadow: 
                -1.5px -1.5px 0 #fff,  
                 1.5px -1.5px 0 #fff,
                -1.5px  1.5px 0 #fff,
                 1.5px  1.5px 0 #fff,
                 0px 0px 8px rgba(255,255,255,1);
        }

        .station-popup {
            display: flex;
            gap: 15px;
            min-width: 280px;
        }

        .station-popup-col {
            flex: 1;
        }

        @media (max-width: 600px) {
            .stats-panel {
                width: calc(100% - 40px);
                top: 10px;
                left: 20px;
            }
        }

        /* --- NEU: MODAL FÜR VERSÜTUNGSLISTE --- */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(45, 45, 45, 0.6);
            backdrop-filter: blur(3px);
            z-index: 2000;
            display: none;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: var(--sbb-white);
            width: 90%;
            max-width: 600px;
            max-height: 80vh;
            border-radius: var(--border-radius);
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .modal-header {
            padding: 1.5rem;
            border-bottom: 1px solid #E5E5E5;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--sbb-white);
        }

        .modal-title {
            font-weight: 700;
            color: var(--sbb-anthracite);
            font-size: 1.2rem;
        }

        .close-btn {
            background: none;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: var(--sbb-grey);
            line-height: 1;
        }

        .close-btn:hover {
            color: var(--sbb-red);
        }

        .modal-body {
            padding: 0;
            overflow-y: auto;
            background: var(--nordic-bg);
        }

        .delay-list-item {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #E5E5E5;
            background: var(--sbb-white);
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .delay-list-item:last-child {
            border-bottom: none;
        }
    </style>
</head>
<body>

    <header>
        <div class="logo">SBB CFF FFS | Live Radar</div>
        <div style="display: flex; gap: 10px; align-items: center;">
            <span id="last-update" style="font-size: 0.75rem; color: var(--sbb-grey);">Aktualisierung...</span>
            <button onclick="updateRadar()" class="btn" style="background: var(--sbb-red); color: white; border: none; padding: 0.5rem 1rem; cursor: pointer; font-weight: 600; font-size: 0.8rem;">Radar Refresh</button>
        </div>
    </header>

    <main>
        <div class="stats-panel">
            <span class="label">Netzwerk-Status</span>
            <!-- NEU: onclick Event hinzugefügt -->
            <div id="delayed-count" class="count-value" onclick="openDelayModal()">0</div>
            <div class="sub-label">Züge mit > 5 Min. Verspätung</div>
            <div id="worst-connection" style="font-size: 0.85rem; border-top: 1px solid #eee; padding-top: -2px; margin-top: 10px; padding-top: 10px;">
                Scanne SBB Kernnetz...
            </div>
        </div>

        <div id="map"></div>
    </main>

    <!-- NEU: HTML Struktur für das Modal (vor den Scripts) -->
    <div id="delayModal" class="modal-overlay" onclick="closeDelayModal(event)">
        <div class="modal-content" onclick="event.stopPropagation()">
            <div class="modal-header">
                <div class="modal-title">Aktuelle Verspätungen (> 5 Min.)</div>
                <button class="close-btn" onclick="closeDelayModal()">&times;</button>
            </div>
            <div id="delay-list-container" class="modal-body">
                <!-- Wird per JS dynamisch abgefüllt -->
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // Konfiguration der Hubs für die Überwachung
        const HUBS = [
            { name: "Zürich HB", coords: [47.3781, 8.5401] },
            { name: "Bern", coords: [46.9488, 7.4391] },
            { name: "Basel SBB", coords: [47.5474, 7.5895] },
            { name: "Lausanne", coords: [46.5168, 6.6291] },
            { name: "Genève", coords: [46.2102, 6.1425] },
            { name: "Luzern", coords: [47.0493, 8.3103] },
            { name: "St. Gallen", coords: [47.4223, 9.3697] },
            { name: "Lugano", coords: [46.0037, 8.9472] },
            { name: "Olten", coords: [47.3520, 7.9077] },
            { name: "Winterthur", coords: [47.5005, 8.7236] },
            { name: "Chur", coords: [46.8539, 9.5303] },
            { name: "Biel/Bienne", coords: [47.1327, 7.2431] }
        ];

        let map;
        let markers = [];
        let polylines = {}; // KORREKTUR: Von Array [] zu Objekt {} für Key-Value Speicherung
        let delayedTrainsList = []; 

        function initMap() {
            map = L.map('map', { 
                zoomControl: true, 
                attributionControl: false 
            }).setView([46.8182, 8.2275], 8);

            // Minimalistisches Kartendesign OHNE integrierte Text-Labels
            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_nolabels/{z}/{x}/{y}{r}.png').addTo(map);

            // Zeichne statische Hauptlinien (vereinfacht)
            drawMainLines();
        }

        function drawMainLines() {
            // Verbindungslinien zwischen den Hubs zur Visualisierung des Netzes
            const connections = [
                ["Zürich HB", "Bern"], ["Bern", "Lausanne"], ["Lausanne", "Genève"],
                ["Zürich HB", "Basel SBB"], ["Zürich HB", "Luzern"], ["Bern", "Luzern"],
                ["Zürich HB", "St. Gallen"], ["Zürich HB", "Winterthur"], ["Winterthur", "St. Gallen"],
                ["Zürich HB", "Chur"], ["Luzern", "Lugano"], ["Bern", "Olten"], ["Olten", "Basel SBB"],
                ["Olten", "Zürich HB"], ["Bern", "Biel/Bienne"], ["Biel/Bienne", "Basel SBB"]
            ];

            connections.forEach(conn => {
                const h1 = HUBS.find(h => h.name === conn[0]);
                const h2 = HUBS.find(h => h.name === conn[1]);
                if (h1 && h2) {
                    const line = L.polyline([h1.coords, h2.coords], {
                        color: '#bbb', // Standardfarbe (Normalbetrieb)
                        weight: 2,
                        opacity: 0.5,
                        dashArray: '5, 10'
                    }).addTo(map);

                    // NEU: Linie bidirektional indexieren für späteren schnellen Zugriff
                    const routeId1 = `${conn[0]}-${conn[1]}`;
                    const routeId2 = `${conn[1]}-${conn[0]}`;
                    polylines[routeId1] = line;
                    polylines[routeId2] = line;
                }
            });
        }

        async function updateRadar() {
            const countDisplay = document.getElementById('delayed-count');
            const worstDisplay = document.getElementById('worst-connection');
            const timeDisplay = document.getElementById('last-update');
            
            let totalDelayed = 0;
            let maxDelay = 0;
            let worstTrain = null;

            // Bestehende Marker entfernen
            markers.forEach(m => map.removeLayer(m));
            markers = [];
            delayedTrainsList = []; // NEU: Liste bei jedem Refresh leeren

            timeDisplay.innerText = "Aktualisiere...";

            try {
                const requests = HUBS.map(hub => 
                    fetch(`https://transport.opendata.ch/v1/stationboard?station=${encodeURIComponent(hub.name)}&limit=40`)
                    .then(res => res.json())
                    .catch(() => null)
                );

                const results = await Promise.all(requests);

                results.forEach((data, index) => {
                    if (!data || !data.stationboard) return;

                    const hubCoords = HUBS[index].coords;
                    let hubHasCriticalDelay = false;
                    let hubMaxDelay = 0;
                    let delayedTrainsCount = 0;

                    data.stationboard.forEach(train => {
                        // KORREKTUR: Datenstruktur der API korrekt auslesen (stop.delay)
                        const delay = parseInt(train.stop?.delay) || 0;
                        
                        // Nur Züge mit > 5 Minuten Verspätung markieren
                        if (delay > 5) {
                            // NEU: Zug für das Modal zwischenspeichern
                            delayedTrainsList.push({
                                category: train.category,
                                number: train.number,
                                from: data.station.name,
                                to: train.to,
                                plannedDep: train.stop?.departure,
                                expectedDep: train.stop?.prognosis?.departure,
                                delay: delay
                            });

                            totalDelayed++;
                            delayedTrainsCount++;
                            hubHasCriticalDelay = true;
                            
                            if (delay > hubMaxDelay) hubMaxDelay = delay;

                            if (delay > maxDelay) {
                                maxDelay = delay;
                                worstTrain = {
                                    name: `${train.category}${train.number}`,
                                    from: data.station.name,
                                    to: train.to,
                                    delay: delay
                                };
                            }

                            // Erstelle Marker für verspäteten Zug leicht versetzt vom Bahnhof
                            const offsetCoords = [
                                hubCoords[0] + (Math.random() - 0.5) * 0.1,
                                hubCoords[1] + (Math.random() - 0.5) * 0.1
                            ];

                            const m = L.circleMarker(offsetCoords, {
                                radius: 8 + (delay / 5), // Grösse korreliert mit Verspätung
                                fillColor: "var(--sbb-red)",
                                color: "#fff",
                                weight: 1,           // Reduziert von 2 auf 1 für einen feineren Rand
                                fillOpacity: 0.4     // Reduziert von 0.8 auf 0.4 (deutlich transparenter)
                            }).addTo(map);

                            m.bindPopup(`
                                <div class="train-popup-title">${train.category}${train.number}</div>
                                <b>Verspätung: <span style="color:var(--sbb-red)">+${delay} Min.</span></b><br>
                                Endstation: ${train.to}<br>
                                Stand: ${data.station.name}
                            `);
                            markers.push(m);
                        }
                    });

                    // --- BAHNHOFS-LABEL & ERWEITERTES POPUP (Ersetzt die grünen Punkte) ---
                    
                    // 1. Endende Züge filtern
                    const terminatingTrains = data.stationboard.filter(t => t.to.includes(data.station.name) || data.station.name.includes(t.to));
                    const trainsHtml = terminatingTrains.length > 0 
                        ? terminatingTrains.map(t => `<div style="font-size: 0.8rem; margin-bottom: 3px;">• ${t.category}${t.number}</div>`).join('')
                        : '<div style="font-size: 0.8rem; color: var(--sbb-grey);">Keine gelisteten Endzüge (nächste 15 Min)</div>';

                    // 2. Status-Heuristik berechnen
                    const hasMajorIssues = hubMaxDelay >= 10 || delayedTrainsCount >= 2;
                    const statusHtml = hasMajorIssues 
                        ? '<strong style="color: var(--sbb-red);">Grosse Einschränkungen</strong><br><span style="font-size:0.8rem;">Erhöhte Verspätungswerte aktiv</span>' 
                        : '<strong style="color: #00a650;">Normalbetrieb</strong><br><span style="font-size:0.8rem;">Regulärer Verkehrsfluss</span>';

                    // 3. Text-Marker generieren
                    const hubIcon = L.divIcon({
                        className: 'hub-label',
                        html: data.station.name,
                        iconSize: null // Passt sich dem Text an
                    });

                    const hubMarker = L.marker(hubCoords, { icon: hubIcon }).addTo(map);
                    
                    hubMarker.bindPopup(`
                        <div class="train-popup-title" style="color: var(--sbb-anthracite);">${data.station.name}</div>
                        <div class="station-popup">
                            <div class="station-popup-col">
                                <strong style="font-size: 0.85rem;">Endstation für:</strong><br>
                                <div style="margin-top: 5px;">${trainsHtml}</div>
                            </div>
                            <div class="station-popup-col" style="border-left: 1px solid #eee; padding-left: 10px;">
                                <strong style="font-size: 0.85rem;">Status:</strong><br>
                                <div style="margin-top: 5px;">${statusHtml}</div>
                            </div>
                        </div>
                    `);
                    markers.push(hubMarker);
                });

                // UI Update
                countDisplay.innerText = totalDelayed;
                if (worstTrain) {
                    worstDisplay.innerHTML = `<strong>Max: +${worstTrain.delay} Min</strong><br>${worstTrain.name} nach ${worstTrain.to}`;
                } else {
                    worstDisplay.innerHTML = "Keine Verspätungen > 5 Min. verzeichnet.";
                }
                
                timeDisplay.innerText = "Stand: " + new Date().toLocaleTimeString('de-CH');

            } catch (error) {
                console.error("Radar-Fehler:", error);
                timeDisplay.innerText = "Fehler!";
            }
        }

        // --- NEU: MODAL STEUERUNG FÜR VERSÜTUNGSLISTE ---
        function openDelayModal() {
            const container = document.getElementById('delay-list-container');
            container.innerHTML = '';

            if (delayedTrainsList.length === 0) {
                container.innerHTML = '<div style="padding: 2rem; text-align: center; color: var(--sbb-grey);">Aktuell keine Verspätungen > 5 Min.</div>';
            } else {
                // Liste absteigend nach Verspätung sortieren
                delayedTrainsList.sort((a, b) => b.delay - a.delay);

                delayedTrainsList.forEach(train => {
                    const plannedTime = train.plannedDep ? new Date(train.plannedDep).toLocaleTimeString('de-CH', { hour: '2-digit', minute: '2-digit' }) : '--:--';
                    const expectedTime = train.expectedDep ? new Date(train.expectedDep).toLocaleTimeString('de-CH', { hour: '2-digit', minute: '2-digit' }) : '--:--';

                    container.innerHTML += `
                        <div class="delay-list-item">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <strong>${train.category} ${train.number}</strong>
                                <span style="color: var(--sbb-red); font-weight: bold;">+${train.delay}'</span>
                            </div>
                            <div style="font-size: 0.85rem; color: var(--sbb-anthracite);">
                                Von: <strong>${train.from}</strong> ➔ Nach: <strong>${train.to}</strong>
                            </div>
                            <div style="font-size: 0.8rem; color: var(--sbb-grey); margin-top: 4px;">
                                Geplante Abfahrt: ${plannedTime} | Erwartet: <span style="color: var(--sbb-red);">${expectedTime}</span>
                            </div>
                        </div>
                    `;
                });
            }
            
            document.getElementById('delayModal').style.display = 'flex';
        }

        // Event-Parameter prüfen, um Schliessen beim Klick auf den Hintergrund (Overlay) zu ermöglichen
        function closeDelayModal(event) {
            if (event && event.target.id !== 'delayModal' && event.type === 'click') return;
            document.getElementById('delayModal').style.display = 'none';
        }

        window.onload = () => {
            initMap();
            updateRadar();
            // Automatischer Refresh alle 60 Sekunden
            setInterval(updateRadar, 60000);
        };
    </script>
</body>
</html>
